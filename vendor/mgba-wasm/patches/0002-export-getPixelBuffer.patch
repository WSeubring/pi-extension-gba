--- a/src/platform/wasm/main.c
+++ b/src/platform/wasm/main.c
@@ -70,6 +70,45 @@
  * Exposed core contract methods
  */

+/* Pixel buffer accessors (pi-extension-gba vendor patch).
+ * The core renders into renderer->outputBuffer, an SDL_PIXELFORMAT_ABGR8888
+ * surface -- RGBA little-endian bytes. Dimensions match the current video
+ * size (240x160 for GBA). Returning a raw pointer into WASM linear memory
+ * lets JS do HEAPU8.subarray(ptr, ptr+size) and avoid copying through the
+ * Emscripten VFS. */
+EMSCRIPTEN_KEEPALIVE uint8_t* getPixelBuffer(void) {
+	if (!renderer || !renderer->outputBuffer) return NULL;
+	return (uint8_t*) renderer->outputBuffer;
+}
+
+EMSCRIPTEN_KEEPALIVE int getPixelBufferSize(void) {
+	if (!renderer || !renderer->core || !renderer->outputBuffer) return 0;
+	unsigned w = 0, h = 0;
+	renderer->core->currentVideoSize(renderer->core, &w, &h);
+	return (int) (w * h * BYTES_PER_PIXEL);
+}
+
+EMSCRIPTEN_KEEPALIVE int getPixelBufferStride(void) {
+	if (!renderer || !renderer->core || !renderer->outputBuffer) return 0;
+	unsigned w = 0, h = 0;
+	renderer->core->currentVideoSize(renderer->core, &w, &h);
+	return (int) (w * BYTES_PER_PIXEL);
+}
+
+EMSCRIPTEN_KEEPALIVE int getPixelBufferWidth(void) {
+	if (!renderer || !renderer->core) return 0;
+	unsigned w = 0, h = 0;
+	renderer->core->currentVideoSize(renderer->core, &w, &h);
+	return (int) w;
+}
+
+EMSCRIPTEN_KEEPALIVE int getPixelBufferHeight(void) {
+	if (!renderer || !renderer->core) return 0;
+	unsigned w = 0, h = 0;
+	renderer->core->currentVideoSize(renderer->core, &w, &h);
+	return (int) h;
+}
+
 EMSCRIPTEN_KEEPALIVE bool screenshot(char* fileName) {
 	bool success = false;
 	int mode = O_CREAT | O_TRUNC | O_WRONLY;
--- a/src/platform/wasm/pre.js
+++ b/src/platform/wasm/pre.js
@@ -348,6 +348,26 @@
   return screenshot(fileName);
 };

+// Vendored by pi-extension-gba: return a Uint8Array VIEW over the
+// current framebuffer (RGBA little-endian, width*height*4 bytes). The
+// returned array is backed by HEAPU8; callers that need to persist it
+// across stepFrames boundaries must .slice() it.
+Module.getPixelBuffer = () => {
+  const getPixelBuffer = cwrap('getPixelBuffer', 'number', []);
+  const getPixelBufferSize = cwrap('getPixelBufferSize', 'number', []);
+  const ptr = getPixelBuffer();
+  const size = getPixelBufferSize();
+  if (!ptr || !size) return null;
+  return HEAPU8.subarray(ptr, ptr + size);
+};
+
+Module.getPixelBufferDimensions = () => {
+  const w = cwrap('getPixelBufferWidth', 'number', [])();
+  const h = cwrap('getPixelBufferHeight', 'number', [])();
+  const s = cwrap('getPixelBufferStride', 'number', [])();
+  return { width: w, height: h, stride: s };
+};
+
 Module.saveState = (slot) => {
   const saveState = cwrap('saveState', 'boolean', ['number']);
   return saveState(slot);
