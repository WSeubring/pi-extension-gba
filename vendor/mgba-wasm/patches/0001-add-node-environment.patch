Subject: [PATCH 1/2] wasm: add node to ENVIRONMENT and extend exported runtime methods
Author: pi-extension-gba vendor-builder

The upstream @thenick775/mgba-wasm@2.4.1 is built with
-s ENVIRONMENT='web,worker', so the Emscripten glue unconditionally
creates DOM Workers and calls browser fetch() for the .wasm. Booting
it from Node fails -- see docs/verify/V1-V2-V7.md.

This patch:

1. Adds 'node' to the ENVIRONMENT list so Emscripten emits the Node
   load path (reads the .wasm from disk, no fetch).
2. Drops -pthread / PTHREAD_POOL_SIZE. SPEC §2/§9 defer worker
   threads to v2, and the Node loader's 'new Worker(url, { type:
   "module" })' calls are the core blocker for headless boot. The
   emulator core will run on the main thread. This is a Node-only
   build -- a browser rebuild must restore those flags.
3. Sets NODEJS_CATCH_EXIT=0 and NODEJS_CATCH_REJECTION=0 so emulator
   crashes cannot kill the host pi process.
4. Sets ALLOW_MEMORY_GROWTH=1 (256 MiB initial, growable).
5. Extends EXPORTED_RUNTIME_METHODS with HEAPU8, HEAPU32, getValue,
   UTF8ToString -- needed by the TS wrapper to read the pixel pointer
   from JS.

Apply with: patch -p1 < 0001-add-node-environment.patch
Base commit: thenick775/mgba @ be30a34e913da1ba7f040d3db4e10f700ce49f76

---
 src/platform/wasm/CMakeLists.txt | 9 +++++----
 1 file changed, 5 insertions(+), 4 deletions(-)

--- a/src/platform/wasm/CMakeLists.txt
+++ b/src/platform/wasm/CMakeLists.txt
@@ -2,10 +2,12 @@
 	-O3 \
 	-s USE_SDL=2 \
 	-s TOTAL_MEMORY=256mb \
-	-s EXPORTED_RUNTIME_METHODS=[\"FS\",\"cwrap\",\"addFunction\",\"removeFunction\"] \
+	-s ALLOW_MEMORY_GROWTH=1 \
+	-s EXPORTED_RUNTIME_METHODS=[\"FS\",\"cwrap\",\"addFunction\",\"removeFunction\",\"HEAPU8\",\"HEAPU32\",\"getValue\",\"UTF8ToString\"] \
 	-s RESERVED_FUNCTION_POINTERS=16 \
-	-s ENVIRONMENT='web,worker' \
-	-s PTHREAD_POOL_SIZE=5 \
+	-s ENVIRONMENT='web,worker,node' \
+	-s NODEJS_CATCH_EXIT=0 \
+	-s NODEJS_CATCH_REJECTION=0 \
 	-s EXPORT_ES6=1 \
 	-s MODULARIZE=1 \
 	-s EXPORT_NAME=${CMAKE_PROJECT_NAME} \
@@ -14,12 +16,11 @@
 	-s MAX_WEBGL_VERSION=2 \
 	-gsource-map \
 	--flto \
-	-pthread \
 	--pre-js ${CMAKE_CURRENT_SOURCE_DIR}/pre.js")
 add_executable(${BINARY_NAME}.js main.c memory.c ../sdl/sdl-audio.c ../sdl/sdl-events.c ../sdl/sdl-text.c)
 set_target_properties(${BINARY_NAME}.js PROPERTIES
 	COMPILE_DEFINITIONS "${OS_DEFINES};${FEATURE_DEFINES};${FUNCTION_DEFINES}"
-	COMPILE_OPTIONS "-s;USE_SDL=2;-pthread"
+	COMPILE_OPTIONS "-s;USE_SDL=2"
 	LINK_DEPENDS "${CMAKE_CURRENT_SOURCE_DIR}/pre.js"
 	OUTPUT_NAME ${BINARY_NAME})
 target_link_libraries(${BINARY_NAME}.js ${BINARY_NAME} ${OS_LIB})
