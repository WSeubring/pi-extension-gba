{
  "name": "pi-extension-gba",
  "version": "0.1.1",
  "description": "GBA emulator as a pi extension. Play Pokémon while the agent works.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "WSeubring",
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "vendor/mgba-wasm/dist/mgba.js",
    "vendor/mgba-wasm/dist/mgba.d.ts",
    "vendor/mgba-wasm/dist/mgba.wasm"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "biome check src tests",
    "lint:fix": "biome check src tests --write",
    "clean": "rm -rf dist",
    "test": "node --test --import tsx --test-concurrency=1 $(find tests -name '*.test.ts')",
    "harness": "expect experiments/pi-harness/drive.exp && node --import tsx experiments/pi-harness/parse.mjs",
    "prepare": "npm run build"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "gba",
    "emulator"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@mariozechner/pi-tui": "^0.67.68",
    "fast-png": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WSeubring/pi-extension-gba.git"
  },
  "bugs": {
    "url": "https://github.com/WSeubring/pi-extension-gba/issues"
  },
  "homepage": "https://github.com/WSeubring/pi-extension-gba#readme",
  "engines": {
    "node": ">=20"
  }
}
